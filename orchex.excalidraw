version":95,"text":"Same idea, different market names: SQS 'visibility timeout', Google Pub/Sub 'ack deadline', orchestration papers 'task lease'. Rule: the lease must outlive the slowest legal node (300s), or a running job gets redelivered and the same API call fires twice.","fontSize":18,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Same idea, different market names: SQS 'visibility timeout', Google Pub/Sub 'ack deadline', orchestration papers 'task lease'. Rule: the lease must outlive the slowest legal node (300s), or a running job gets redelivered and the same API call fires twice.","autoResize":true,"lineHeight":1.25,"index":"c0QV"},{"id":"N0Q7bUUuz49Hpj0aGh1ZP","type":"rectangle","x":7545.718824618798,"y":9140.071511575481,"width":2760,"height":720,"angle":0,"strokeColor":"#adb5bd","backgroundColor":"#f8f9fa","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":109587373,"versionNonce":1591684589,"isDeleted":false,"boundElements":[],"updated":1784708679981,"link":null,"locked":false,"version":95,"index":"c0QW"},{"id":"i1FfuurF0StyvlZ8DYamz","type":"text","x":7575.718824618798,"y":9165.071511575481,"width":668.16,"height":40,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":1430269453,"versionNonce":134015053,"isDeleted":false,"boundElements":[],"updated":1784708679981,"link":null,"locked":false,"version":95,"text":"3 \u2014 Duplicates: two workers, one job","fontSize":32,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"3 \u2014 Duplicates: two workers, one job","autoResize":true,"lineHeight":1.25,"index":"c0QX"},{"id":"7Y9ZGysfMRsTO_KSnwx_l","type":"text","x":7575.718824618798,"y":9212.071511575481,"width":1033.56,"height":22.5,"ang