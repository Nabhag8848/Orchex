      "width": 720,
      "height": 18.75,
      "strokeColor": "#0F172A",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "So Step Functions isn’t cheating — it’s buying the orchestrator. We just shouldn’t buy the orchestrator if the orchestrator is our product.",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "So Step Functions isn’t cheating — it’s buying the orchestrator. We just shouldn’t buy the orchestrator if the orchestrator is our product.",
      "autoResize": false,
      "lineHeight": 1.25,
      "version": 81,
      "index": "b9Y"
    },
