      "updated": 1783746147478,
      "link": null,
      "locked": false,
      "text": "{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"type\": \"response\",\n  \"category\": \"terminal\",\n  \"display_name\": \"Response\",\n  \"config_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"status_code\"],\n    \"properties\": {\n      \"status_code\": {\n        \"type\": \"integer\",\n        \"enum\": [\n          100, 101, 102, 103,\n          200, 201, 202, 203, 204, 205, 206, 207, 208, 226,\n          300, 301, 302, 303, 304, 305, 307, 308,\n          400, 401, 402, 403, 404, 405, 406, 407, 408, 409, 410,\n          411, 412, 413, 414, 415, 416, 417, 418, 421, 422, 423,\n          424, 425, 426, 428, 429, 431, 451,\n          500, 501, 502, 503, 504, 505, 506, 507, 508, 510, 511\n        ],\n        \"default\": 200\n      },\n      \"body_template\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 65536,\n        \"description\": \"Template over input.data for final response body\"\n      },\n      \"headers\": {\n        \"type\": \"object\",\n        \"propertyNames\": {\n          \"type\": \"string\",\n          \"minLength\": 1,\n          \"maxLength\": 256,\n          \"pattern\": \"^[A-Za-z0-9!#$%&'*+.^_`|~-]+$\"\n        },\n        \"additionalProperties\": {\n          \"type\": \"string\",\n          \"maxLength\": 8192\n        }\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"input_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"output_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": \"object\",\n        \"required\": [\"status_code\", \"body\"],\n        \"properties\": {\n          \"status_code\": {\n            \"type\": \"integer\",\n            \"enum\": [\n              100, 101, 102, 103,\n              200, 201, 202, 203, 204, 205, 206, 207, 208, 226,\n              300, 301, 302, 303, 304, 305, 307, 308,\n              400, 401, 402, 403, 404, 405, 406, 407, 408, 409, 410,\n              411, 412, 413, 414, 415, 416, 417, 418, 421, 422, 423,\n              424, 425, 426, 428, 429, 431, 451,\n              500, 501, 502, 503, 504, 505, 506, 507, 508, 510, 511\n            ]\n          },\n          \"headers\": {\n            \"type\": \"object\",\n            \"propertyNames\": {\n              \"type\": \"string\",\n              \"minLength\": 1,\n              \"maxLength\": 256,\n              \"pattern\": \"^[A-Za-z0-9!#$%&'*+.^_`|~-]+$\"\n            },\n            \"additionalProperties\": {\n              \"type\": \"string\",\n              \"maxLength\": 8192\n            }\n          },\n          \"body\": {\n            \"type\": [\"object\", \"array\", \"string\", \"number\", \"boolean\", \"null\"]\n          }\n        },\n        \"additionalProperties\": false\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"error_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"type\", \"code\", \"message\", \"retryable\"],\n    \"properties\": {\n      \"type\": {\n        \"type\": \"string\",\n        \"enum\": [\"validation\", \"operation\", \"internal\"],\n        \"description\": \"Error class used for UI routing and retry policy\"\n      },\n      \"code\": {\n        \"type\": \"string\",\n        \"enum\": [\"INVALID_INPUT\", \"TEMPLATE_ERROR\", \"INTERNAL_ERROR\"]\n      },\n      \"message\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 512,\n        \"description\": \"Short user-facing summary\"\n      },\n      \"description\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 2048,\n        \"description\": \"Optional remediation guidance shown in run history\"\n      },\n      \"retryable\": {\n        \"type\": \"boolean\"\n      },\n      \"retry_after_ms\": {\n        \"type\": \"integer\",\n        \"minimum\": 0,\n        \"maximum\": 3600000\n      },\n      \"details\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"parameter\": {\n            \"type\": \"string\",\n            \"maxLength\": 256,\n            \"description\": \"Config or input field that caused the failure\"\n          },\n          \"template\": {\n            \"type\": \"string\",\n            \"maxLength\": 65536\n          },\n          \"cause\": {\n            \"type\": \"string\",\n            \"maxLength\": 4096\n          }\n        },\n        \"additionalProperties\": false\n      }\n    },\n    \"additionalProperties\": false\n  }\n}\n",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"type\": \"response\",\n  \"category\": \"terminal\",\n  \"display_name\": \"Response\",\n  \"config_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"status_code\"],\n    \"properties\": {\n      \"status_code\": {\n        \"type\": \"integer\",\n        \"enum\": [\n          100, 101, 102, 103,\n          200, 201, 202, 203, 204, 205, 206, 207, 208, 226,\n          300, 301, 302, 303, 304, 305, 307, 308,\n          400, 401, 402, 403, 404, 405, 406, 407, 408, 409, 410,\n          411, 412, 413, 414, 415, 416, 417, 418, 421, 422, 423,\n          424, 425, 426, 428, 429, 431, 451,\n          500, 501, 502, 503, 504, 505, 506, 507, 508, 510, 511\n        ],\n        \"default\": 200\n      },\n      \"body_template\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 65536,\n        \"description\": \"Template over input.data for final response body\"\n      },\n      \"headers\": {\n        \"type\": \"object\",\n        \"propertyNames\": {\n          \"type\": \"string\",\n          \"minLength\": 1,\n          \"maxLength\": 256,\n          \"pattern\": \"^[A-Za-z0-9!#$%&'*+.^_`|~-]+$\"\n        },\n        \"additionalProperties\": {\n          \"type\": \"string\",\n          \"maxLength\": 8192\n        }\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"input_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"output_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": \"object\",\n        \"required\": [\"status_code\", \"body\"],\n        \"properties\": {\n          \"status_code\": {\n            \"type\": \"integer\",\n            \"enum\": [\n              100, 101, 102, 103,\n              200, 201, 202, 203, 204, 205, 206, 207, 208, 226,\n              300, 301, 302, 303, 304, 305, 307, 308,\n              400, 401, 402, 403, 404, 405, 406, 407, 408, 409, 410,\n              411, 412, 413, 414, 415, 416, 417, 418, 421, 422, 423,\n              424, 425, 426, 428, 429, 431, 451,\n              500, 501, 502, 503, 504, 505, 506, 507, 508, 510, 511\n            ]\n          },\n          \"headers\": {\n            \"type\": \"object\",\n            \"propertyNames\": {\n              \"type\": \"string\",\n              \"minLength\": 1,\n              \"maxLength\": 256,\n              \"pattern\": \"^[A-Za-z0-9!#$%&'*+.^_`|~-]+$\"\n            },\n            \"additionalProperties\": {\n              \"type\": \"string\",\n              \"maxLength\": 8192\n            }\n          },\n          \"body\": {\n            \"type\": [\"object\", \"array\", \"string\", \"number\", \"boolean\", \"null\"]\n          }\n        },\n        \"additionalProperties\": false\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"error_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"type\", \"code\", \"message\", \"retryable\"],\n    \"properties\": {\n      \"type\": {\n        \"type\": \"string\",\n        \"enum\": [\"validation\", \"operation\", \"internal\"],\n        \"description\": \"Error class used for UI routing and retry policy\"\n      },\n      \"code\": {\n        \"type\": \"string\",\n        \"enum\": [\"INVALID_INPUT\", \"TEMPLATE_ERROR\", \"INTERNAL_ERROR\"]\n      },\n      \"message\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 512,\n        \"description\": \"Short user-facing summary\"\n      },\n      \"description\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 2048,\n        \"description\": \"Optional remediation guidance shown in run history\"\n      },\n      \"retryable\": {\n        \"type\": \"boolean\"\n      },\n      \"retry_after_ms\": {\n        \"type\": \"integer\",\n        \"minimum\": 0,\n        \"maximum\": 3600000\n      },\n      \"details\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"parameter\": {\n            \"type\": \"string\",\n            \"maxLength\": 256,\n            \"description\": \"Config or input field that caused the failure\"\n          },\n          \"template\": {\n            \"type\": \"string\",\n            \"maxLength\": 65536\n          },\n          \"cause\": {\n            \"type\": \"string\",\n            \"maxLength\": 4096\n          }\n        },\n        \"additionalProperties\": false\n      }\n    },\n    \"additionalProperties\": false\n  }\n}\n",
