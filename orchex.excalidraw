    {
      "angle": 0,
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "MH6Yp12wVqcU1So_upIFN"
      ],
      "frameId": null,
      "seed": 1270383616,
      "versionNonce": 2101019648,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1783935457733,
      "link": null,
      "locked": false,
      "type": "text",
      "id": "Iu8xIKVhhjtpBBfskvxD5",
      "x": 2354.516065537358,
      "y": 4654.065314095467,
      "width": 720,
      "height": 187.5,
      "strokeColor": "#0F172A",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "Pros:\n• You own the core — right choice when workflow builder IS the product\n• Full control over DAG rules, error schemas, resume, observability\n• Lambda/E2B can be swappable sandbox adapter, not the brain, more extensible\n• Fits our scale path (1M runs/day) with worker autoscaling\n\nCons:\n• You must build Temporal-like internals (simpler cousin): retries, idempotency, poison messages\n• More engineering than Step Functions for an internal tool\n• Easy to under-build durability if careless.",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pros:\n• You own the core — right choice when workflow builder IS the product\n• Full control over DAG rules, error schemas, resume, observability\n• Lambda/E2B can be swappable sandbox adapter, not the brain, more extensible\n• Fits our scale path (1M runs/day) with worker autoscaling\n\nCons:\n• You must build Temporal-like internals (simpler cousin): retries, idempotency, poison messages\n• More engineering than Step Functions for an internal tool\n• Easy to under-build durability if careless.",
      "autoResize": false,
      "lineHeight": 1.25,
      "version": 235,
      "index": "bH0"
    },
