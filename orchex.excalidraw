e the graph; AWS runs and persists it.","autoResize":false,"lineHeight":1.25,"version":322,"index":"bHz"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["09TxZABQ93uV1Z2aSLqQD"],"frameId":null,"seed":475249664,"versionNonce":176765952,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"ellipse","id":"XMeHpx7u-LlXLbTzJtfQL","x":-1012.2195994356621,"y":767.7496901427708,"width":40,"height":40,"strokeColor":"#22C55E","backgroundColor":"#22C55E","roundness":null,"version":322,"index":"bI0"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["09TxZABQ93uV1Z2aSLqQD"],"frameId":null,"seed":1383873536,"versionNonce":1577171968,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"text","id":"jmvyKmi-F1aiVv4NN3dIU","x":-1001.2195994356621,"y":777.7496901427708,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"I","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"I","autoResize":true,"lineHeight":1.25,"version":322,"index":"bI1"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["09TxZABQ93uV1Z2aSLqQD"],"frameId":null,"seed":798276608,"versionNonce":778714112,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"rectangle","id":"eA1vaBwZWTLXLIO4D3gti","x":-1732.219599435662,"y":763.7496901427708,"width":760,"height":78.75,"strokeColor":"#4ADE80","backgroundColor":"#DCFCE7","roundness":{"type":3},"version":322,"index":"bI2"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["09TxZABQ93uV1Z2aSLqQD"],"frameId":null,"seed":1436367872,"versionNonce":1573043200,"isDeleted":false,"boundElements":[],"updated":17839354