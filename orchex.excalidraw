      "type": "text",
      "id": "paY-BG5CYM4GaaV0OBveb",
      "x": 2549.4664695256834,
      "y": 5274.077546286774,
      "width": 720,
      "height": 56.25,
      "strokeColor": "#0F172A",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "Exactly. Outsourcing isolation (Lambda) is fine.\nOutsourcing the execution brain is fine for internal tools.\nOutsourcing the brain when the product IS the workflow engine — that’s the mistake.",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Exactly. Outsourcing isolation (Lambda) is fine.\nOutsourcing the execution brain is fine for internal tools.\nOutsourcing the brain when the product IS the workflow engine — that’s the mistake.",
      "autoResize": false,
      "lineHeight": 1.25,
      "version": 81,
      "index": "b9d"
    },
    {
      "angle": 0,
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "seed": 2025751552,
      "versionNonce": 1288471552,
      "isDeleted": true,
      "boundElements": [],
