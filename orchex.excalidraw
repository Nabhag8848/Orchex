D4ED8","backgroundColor":"transparent","roundness":null,"text":"Candidate","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":340,"index":"c1I3"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["fq_g8EaOT7ExBRdtZIFRa"],"frameId":null,"seed":1895964038,"versionNonce":1394634374,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"8WpvtYoxVtBcOVVUL3Yqf","x":-14409.504583366745,"y":29509.010705357716,"width":720,"height":150,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"Core concepts:\n• Workflow — orchestration code (deterministic): what runs next, branches, waits\n• Activity — side effects: HTTP, Composio, sandboxed JS, DB writes\n• Worker — polls Temporal, runs workflows + activities\n• Event history — durable log; enables crash recovery via replay\n• Task queues — how work is routed to workers\n\nMental model: durable brain + history; your node executors become Activities.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Core concepts:\n• Workflow — orchestration code (deterministic): what runs next, branches, waits\n• Activity — side effects: HTTP, Composio, sandboxed JS, DB writes\n• Worker — polls Temporal, runs workflows + activities\n• Event history — durable log; enables crash recovery via replay\n• Task queues — how work is routed to workers\n\nMental model: durable brain + history; your node executors become Activities.","autoResize":false,"lineHeight":1.25,"version":340,"index":"c1I4"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["dMyKUtokPUXs6bcKqoFwr"],"frameId":null,"seed":1462795462,"versionNonce":1078469850,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":n