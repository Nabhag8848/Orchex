      "type": "text",
      "id": "u1yHp7oTWKxB_e3CsfG_n",
      "x": 3985.5320762891033,
      "y": 2750.451390461154,
      "width": 720,
      "height": 112.5,
      "strokeColor": "#0F172A",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "For a workflow execution layer, people usually discuss three options:\n1) AWS Step Functions\n2) Temporal\n3) Queues + Workers + Durable Lambda for isolation\n\nHow would you choose between them?",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For a workflow execution layer, people usually discuss three options:\n1) AWS Step Functions\n2) Temporal\n3) Queues + Workers + Durable Lambda for isolation\n\nHow would you choose between them?",
      "autoResize": false,
      "lineHeight": 1.25,
      "version": 36,
      "index": "bBV"
    },
