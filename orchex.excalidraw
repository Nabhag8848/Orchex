    {
      "angle": 0,
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "QDSVCqORFdwp0oAWn-ujT"
      ],
      "frameId": null,
      "seed": 1961493504,
      "versionNonce": 2016164864,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1783935042977,
      "link": null,
      "locked": false,
      "type": "text",
      "id": "_SThD0eFuU_kDYBYfmGGH",
      "x": 177.48505004317894,
      "y": 5804.401990852075,
      "width": 720,
      "height": 243.75,
      "strokeColor": "#0F172A",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "Pros:\n• You own the core — right choice when workflow builder IS the product\n• Full control over DAG rules, error schemas, resume, observability\n• Matches Twenty/Sim-style architectures\n• Lambda/E2B is a swappable sandbox adapter, not the brain\n• Fits our scale path (1M runs/day) with worker autoscaling\n\nCons:\n• You must build Temporal-like internals (simpler cousin): retries, idempotency, poison messages\n• More engineering than Step Functions for an internal tool\n• Easy to under-build durability if careless\n\nUse when: Orchex / Sim / Gumloop-class product — don’t outsource the core.",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pros:\n• You own the core — right choice when workflow builder IS the product\n• Full control over DAG rules, error schemas, resume, observability\n• Matches Twenty/Sim-style architectures\n• Lambda/E2B is a swappable sandbox adapter, not the brain\n• Fits our scale path (1M runs/day) with worker autoscaling\n\nCons:\n• You must build Temporal-like internals (simpler cousin): retries, idempotency, poison messages\n• More engineering than Step Functions for an internal tool\n• Easy to under-build durability if careless\n\nUse when: Orchex / Sim / Gumloop-class product — don’t outsource the core.",
      "autoResize": false,
      "lineHeight": 1.25,
      "version": 75,
      "index": "bFU"
    },
