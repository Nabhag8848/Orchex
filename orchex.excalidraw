","autoResize":true,"lineHeight":1.25,"version":340,"index":"c1I8"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["dMyKUtokPUXs6bcKqoFwr"],"frameId":null,"seed":1344334278,"versionNonce":1003763290,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"t1oepOdaYHzNCdhFb5pHb","x":-14201.504583366745,"y":29735.010705357716,"width":720,"height":18.75,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"Pros and cons?","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Pros and cons?","autoResize":false,"lineHeight":1.25,"version":340,"index":"c1I9"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["SVqUK-J8-9_32sSssx3MG"],"frameId":null,"seed":959168774,"versionNonce":1131705414,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"ellipse","id":"po2G0NyJTrF_kwE7hnexw","x":-14485.504583366748,"y":29795.760705357716,"width":40,"height":40,"strokeColor":"#3B82F6","backgroundColor":"#3B82F6","roundness":null,"version":340,"index":"c1IA"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["SVqUK-J8-9_32sSssx3MG"],"frameId":null,"seed":1096396870,"versionNonce":863001370,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"TPtc-niX-TGNuQk0IlAmu","x":-14474.504583366745,"y":29805.760705357716,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"C","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"C","autoResize":true,"lineHeight":1.25,"version":340,"index":"c1IB"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["SVqUK-J8-9_32sSssx3MG"],"frameId":null,"seed":1149745030,"versionNonce":1051327366,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"rectangle","id":"FvB3yRu7RZ5wjIhALeocV","x":-14429.504583366745,"y":29791.760705357716,"width":760,"height":303.75,"strokeColor":"#60A5FA","backgroundColor":"#DBEAFE","roundness":{"type":3},"version":340,"index":"c1IC"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["SVqUK-J8-9_32sSssx3MG"],"frameId":null,"seed":452122310,"versionNonce":1437198298,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"Wzj59NXuV7aq4O6zOaf-A","x":-14409.504583366745,"y":29805.760705357716,"width":130,"height":16.25,"strokeColor":"#1D4ED8","backgroundColor":"transparent","roundness":null,"text":"Candidate","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":340,"index":"c1ID"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["SVqUK-J8-9_32sSssx3MG"],"frameId":null,"seed":221777414,"versionNonce":539794118,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"0CbqHW5EzFzC9pjtYTeCP","x":-14409.504583366745,"y":29829.760705357716,"width":720,"height":243.75,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"Pros:\n• Excellent durability / resume / retries for long-running flows\n• Code-first workflows; strong failure semantics\n• You still own product UI, schemas, node types\n• Better “execution platform” than Step Functions if workflows are long/complex\n\nCons:\n• Real ops cost (Temporal Cloud or self-host cluster)\n• Learning curve (determinism, replay, versioning)\n• Overkill for simple short DAGs\n• Still not a full workflow-builder product — you build Orchex around it\n\nUse when: internal tool needing a serious long-running execution layer.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Pros:\n• Excellent durability / resume / retries for long-running flows\n• Code-first workflows; strong failure semantics\n• You still own product UI, schemas, node types\n• Better “execution platform” than Step Functions if workflows are long/complex\n\nCons:\n• Real ops cost (Temporal Cloud or self-host cluster)\n• Learning curve (determinism, replay, versioning)\n• Overkill for simple short DAGs\n• Still not a full workflow-builder product — you build Orchex around it\n\nUse when: internal tool needing a serious long-running execution layer.","autoResize":false,"lineHeight":1.25,"version":340,"index":"c1IE"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"seed":1213488454,"versionNonce":982768794,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"rectangle","id":"K84M563h1vijGvmhS3QZS","x":-14485.504583366748,"y":30123.510705357716,"width":521.675177924522,"height":42,"strokeColor":"#E11D48","backgroundColor":"#E11D48","roundness":{"type":3},"version":349,"index":"c1IF"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"seed":1369752710,"versionNonce":1318670854,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"ywAU7fWnfz-UhWhRF0KgU","x":-14469.504583366745,"y":30131.510705357716,"width":460.1509357851104,"height":22.5,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"4 · Queue + Workers + Durable Lambda Functions","fontSize":18,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"4 · Queue + Workers + Durable Lambda Functions","aut