      "updated": 1783746497044,
      "link": null,
      "locked": false,
      "text": "{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"type\": \"start\",\n  \"category\": \"trigger\",\n  \"display_name\": \"Start\",\n  \"config_schema\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"description\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 512\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"input_schema\": {\n    \"type\": \"object\",\n    \"properties\": {},\n    \"additionalProperties\": false\n  },\n  \"output_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": \"object\",\n        \"required\": [\"payload\"],\n        \"properties\": {\n          \"payload\": {\n            \"type\": [\"object\", \"array\", \"string\", \"number\", \"boolean\", \"null\"]\n          }\n        },\n        \"additionalProperties\": false\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"error_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"type\", \"code\", \"message\", \"retryable\"],\n    \"properties\": {\n      \"type\": {\n        \"type\": \"string\",\n        \"enum\": [\"validation\", \"internal\"],\n        \"description\": \"Error class used for UI routing and retry policy\"\n      },\n      \"code\": {\n        \"type\": \"string\",\n        \"enum\": [\"INVALID_TRIGGER_PAYLOAD\", \"INTERNAL_ERROR\"]\n      },\n      \"message\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 512,\n        \"description\": \"Short user-facing summary\"\n      },\n      \"description\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 2048,\n        \"description\": \"Optional remediation guidance shown in run history\"\n      },\n      \"retryable\": {\n        \"type\": \"boolean\"\n      },\n      \"retry_after_ms\": {\n        \"type\": \"integer\",\n        \"minimum\": 0,\n        \"maximum\": 3600000\n      },\n      \"details\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"parameter\": {\n            \"type\": \"string\",\n            \"maxLength\": 256,\n            \"description\": \"Config or input field that caused the failure\"\n          },\n          \"cause\": {\n            \"type\": \"string\",\n            \"maxLength\": 4096\n          }\n        },\n        \"additionalProperties\": false\n      }\n    },\n    \"additionalProperties\": false\n  }\n}\n",
