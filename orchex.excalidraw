":729.0152347366584,"y":31340.979549962176,"width":278.4,"height":37.5,"angle":0,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":1687015494,"versionNonce":966740762,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"version":98,"text":"the write the dead worker\nnever could (guarded, as always)","fontSize":15,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"the write the dead worker\nnever could (guarded, as always)","autoResize":true,"lineHeight":1.25,"index":"c1SV"},{"id":"aH22SVsm4Z69xZpOeJXW0","type":"text","x":-910.9847652633416,"y":31320.979549962176,"width":828.2399999999999,"height":63.75,"angle":0,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":741857158,"versionNonce":723651462,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"version":98,"text":"Why 5? A healthy message is delivered once — twice after an unlucky lease expiry.\nOnly a genuine worker-killer racks up 5. And auto-retries never inflate the counter:\neach retry is a NEW message starting at delivery 1.","fontSize":17,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Why 5? A healthy message is delivered once — twice after an unlucky lease expiry.\nOnly a genuine worker-killer racks up 5. And auto-retries never inflate the counter:\neach retry is a NEW message starting at delivery 1.","autoResize":true,"lineHeight":1.25,"index":"c1SW"},{"id":"CSyKhheuFKeA9hj3Nsw_o","type":"text","x":-910.9847652633416,"y":31600.979549962176,"width":2578.68,"height":22.5,"angle":0,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth"