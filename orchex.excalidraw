containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":340,"index":"c1Hr"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["3o-Itj9P26TidpfFF0cgs"],"frameId":null,"seed":2075981446,"versionNonce":1888414470,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"hGQCddTHb77asOYP3XXJw","x":-14409.504583366745,"y":29022.510705357716,"width":720,"height":243.75,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"Pros:\n• Almost no custom orchestrator to build\n• Built-in retries, branching, timeouts, visual console\n• Great if you’re already deep on AWS\n• Fast for internal tools / moderate volume\n\nCons:\n• You don’t own the execution core — weak if workflow IS the product\n• Cost grows with many fine-grained state transitions\n• Lock-in; hard to self-host or go multi-cloud\n• Custom semantics (our error envelopes, resume UX, traces) get awkward\n\nUse when: internal tool + AWS-native stack.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Pros:\n• Almost no custom orchestrator to build\n• Built-in retries, branching, timeouts, visual console\n• Great if you’re already deep on AWS\n• Fast for internal tools / moderate volume\n\nCons:\n• You don’t own the execution core — weak if workflow IS the product\n• Cost grows with many fine-grained state transitions\n• Lock-in; hard to self-host or go multi-cloud\n• Custom semantics (our error envelopes, resume UX, traces) get awkward\n\nUse when: internal tool + AWS-native stack.","autoResize":false,"lineHeight":1.25,"version":340,"index":"c1Hs"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"seed":1462252998,"versionNonce":1416474714,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":f