ndColor":"#DBEAFE","roundness":{"type":3},"version":322,"index":"bIf"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["3FloWMdewlCHJDE-dFgVt"],"frameId":null,"seed":606649344,"versionNonce":528366592,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"text","id":"q_0xIt5Gl4fkAaHxeICaV","x":-1920.219599435662,"y":2166.2496901427708,"width":130,"height":16.25,"strokeColor":"#1D4ED8","backgroundColor":"transparent","roundness":null,"text":"Candidate","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":322,"index":"bIg"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["3FloWMdewlCHJDE-dFgVt"],"frameId":null,"seed":397491200,"versionNonce":207010816,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"text","id":"0Fet30J4de4wr9LVCOJBu","x":-1920.219599435662,"y":2190.2496901427708,"width":720,"height":187.5,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"Core concepts:\n• Queue — job per node step\n• Worker — orchestrates: load run, pick executor, checkpoint, enqueue next\n• Executors — API / Conditional / Function / Integration / Response\n• Durable Lambda (or similar sandbox) — ONLY for untrusted Function code isolation\n• Postgres — workflow_runs, current_node_id, error, context\n\nFlow:\nenqueue execute(node) → success → checkpoint → enqueue successor(s)\nfailure → store error → resume later from that node","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Core concepts:\n• Queue — job per node step\n• Worker — orchestrates: load run, pick executor, checkpoint, enqueue next\n• Executors — API / Conditional / Function / Integration / Response\n• Durable Lambda (or similar sandbox) — ONLY for untrusted Function code isolation\n• Postgres — workflow_runs, current_node_id, error, context\n\nFlow:\nenqueue execute(node) → success → checkpoint → enqueue successor(s)\nfailure → store error → resume later from that node","autoResize":false,"lineHeight":1.25,"version":324,"index":"bIh"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["xNRpWn9VLp98OiEr9zpPd"],"frameId":null,"seed":103398400,"versionNonce":1243560960,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"ellipse","id":"ax5lXJ2C75qef0KP69QTw","x":-1012.2195994356621,"y":2419.7496901427708,"width":40,"height":40,"strokeColor":"#22C55E","backgroundColor":"#22C55E","roundness":null,"version":322,"index":"bIi"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["xNRpWn9VLp98OiEr9zpPd"],"frameId":null,"seed":294796288,"versionNonce":987216896,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"text","id":"MlW5KYhEyek1Fwo6mdynk","x":-1001.2195994356621,"y":2429.7496901427708,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"I","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"I","autoResize":true,"lineHeight":1.25,"version":322,"index":"bIj"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["xNRpWn9VLp98OiEr9zpPd"],"frameId":null,"seed":468368384,"versionNonce":8403968,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"rectangle","id":"VybhShVpltx6RSPNinmpT","x":-1732.219599435662,"y":2415.7496901427708,"width":760,"height":78.75,"strokeColor":"#4ADE80","backgroundColor":"#DCFCE7","roundness":{"type":3},"version":322,"index":"bIk"},{"angle":0,"fillStyle":"solid","stro