62,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"x46x8BVXRRyWf9RNRBwRE","x":-14409.504583366745,"y":30650.510705357716,"width":130,"height":16.25,"strokeColor":"#1D4ED8","backgroundColor":"transparent","roundness":null,"text":"Candidate","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":340,"index":"c1IZ"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["rw2wCkSEY0OZD9B1-Dw7z"],"frameId":null,"seed":1992066438,"versionNonce":405774982,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"b2MPz5McF_C9L2SY9VH9e","x":-14409.504583366745,"y":30674.510705357716,"width":720,"height":187.5,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"Pros:\n• You own the core — right choice when workflow builder IS the product\n• Full control over DAG rules, error schemas, resume, observability\n• Lambda/E2B can be swappable sandbox adapter, not the brain, more extensible\n• Fits our scale path (1M runs/day) with worker autoscaling\n\nCons:\n• You must build Temporal-like internals (simpler cousin): retries, idempotency, poison messages\n• More engineering than Step Functions for an internal tool\n• Easy to under-build durability if careless.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Pros:\n• You own the core — right choice when workflow builder IS the product\n• Full control over DAG rules, error schemas, resume, observability\n• Lambda/E2B can be swappable sandbox adapter, not the brain, more extensible\n• Fits our scale path (1M runs/day) with worker autoscaling\n\nCons:\n• You must build Temporal-like internals (simpler cousin): retries, idempotency, poison messages\n• More engineering than Step Functions for an internal tool\n• Easy to under-build durability if careless.","autoResize":false,"lineHeight":1.25,"version":376,"index":"c1Ia"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"seed":157148358,"versionNonce":2113286362,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"rectangle","id":"blJBC2x7Ot-_RRpKcQLYW","x":-14485.504583366748,"y":30968.260705357716,"width":220,"height":42,"strokeColor":"#0F172A","backgroundColor":"#0F172A","roundness":{"type":3},"version":340,"index":"c1Ib"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"seed":1460755462,"versionNonce":677732806,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"HDLrYL88gzg_k1hmWMSu0","x":-14469.504583366745,"y":30976.260705357716,"width":180,"height":22.5,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"Decision summary","fontSize":18,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Decision summary","autoResize":true,"lineHeight":1.25,"version":340,"index":"c1Ic"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["7NgfHnKsBD37bOqAMUUBP"],"frameId":null,"seed":1708387142,"versionNonce":74384794,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"ellipse","id":"7POQRmCQK9JCKTJSYSfTD","x":-13501.504583366745,"y":31032.260705357716,"width":40,"height":40,"strokeColor":"#22C55E","backgroundColor":"#22C55E","roundness":null,"version":340,"index":"c1Id"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["7NgfHnKsBD37bOqAMUUBP"],"frameId":null,"seed":1946325638,"versionNonce":35731718,"isDeleted":false,"boundElements":[