      "width": 720,
      "height": 56.25,
      "strokeColor": "#0F172A",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "Exactly. Outsourcing isolation (Lambda) is fine.\nOutsourcing the execution brain is fine for internal tools.\nOutsourcing the brain when the product IS the workflow engine — that’s the mistake.",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Exactly. Outsourcing isolation (Lambda) is fine.\nOutsourcing the execution brain is fine for internal tools.\nOutsourcing the brain when the product IS the workflow engine — that’s the mistake.",
      "autoResize": false,
      "lineHeight": 1.25,
      "version": 199,
      "index": "bHM"
    },
