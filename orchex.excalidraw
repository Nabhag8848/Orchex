:15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Is the system read-heavy or write-heavy? Does that change storage choice?\nWrite-heavy — we log state transitions and (later) node traces, plus historical/analytics data.\nEntity relationships still matter though.\n\n→ Postgres for OLTP\n→ ClickHouse for OLAP (logs / traces / analytics)","autoResize":false,"lineHeight":1.25,"version":125,"index":"c1Gc"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["cbVS8B5KVorD51P8xjHTo"],"frameId":null,"seed":849049670,"versionNonce":299087642,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"id":"m-VkTMneJtC8eNe8dK44n","type":"ellipse","x":-13083.604142570757,"y":29795.72452113669,"width":40,"height":40,"strokeColor":"#3B82F6","backgroundColor":"#3B82F6","roundness":null,"version":123,"index":"c1Gd"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["cbVS8B5KVorD51P8xjHTo"],"frameId":null,"seed":978354054,"versionNonce":1874485126,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"id":"blLERJPcCBNmIoSQgBfyX","type":"text","x":-13072.604142570757,"y":29805.72452113669,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"C","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"C","autoResize":true,"lineHeight":1.25,"version":123,"index":"c1Ge"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["cbVS8B5KVorD51P8xjHTo"],"frameId":null,"seed":1818402502,"versionNonce":1195492314,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"id":"mrnSpMZl-ww4Eq3x5m9UQ","type":"rectangle","x":-13027.604142570757,"y":29791.72452113669,"width":720,"height":135.26709