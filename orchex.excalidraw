      "locked": false,
      "type": "text",
      "id": "Tq8GWkcaIvAWQrEeiptMT",
      "x": 3777.5320762891033,
      "y": 4515.951390461154,
      "width": 720,
      "height": 243.75,
      "strokeColor": "#0F172A",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "Pros:\n• Excellent durability / resume / retries for long-running flows\n• Code-first workflows; strong failure semantics\n• You still own product UI, schemas, node types\n• Better “execution platform” than Step Functions if workflows are long/complex\n\nCons:\n• Real ops cost (Temporal Cloud or self-host cluster)\n• Learning curve (determinism, replay, versioning)\n• Overkill for simple short DAGs\n• Still not a full workflow-builder product — you build Orchex around it\n\nUse when: internal tool needing a serious long-running execution layer.",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pros:\n• Excellent durability / resume / retries for long-running flows\n• Code-first workflows; strong failure semantics\n• You still own product UI, schemas, node types\n• Better “execution platform” than Step Functions if workflows are long/complex\n\nCons:\n• Real ops cost (Temporal Cloud or self-host cluster)\n• Learning curve (determinism, replay, versioning)\n• Overkill for simple short DAGs\n• Still not a full workflow-builder product — you build Orchex around it\n\nUse when: internal tool needing a serious long-running execution layer.",
      "autoResize": false,
      "lineHeight": 1.25,
      "version": 36,
      "index": "bCI"
    },
