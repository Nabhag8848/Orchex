      "strokeColor": "#0F172A",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "So Step Functions isn’t cheating — it’s buying the orchestrator. You just shouldn’t buy the orchestrator if the orchestrator is your product?",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "So Step Functions isn’t cheating — it’s buying the orchestrator. You just shouldn’t buy the orchestrator if the orchestrator is your product?",
