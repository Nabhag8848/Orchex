664103,"isDeleted":false,"boundElements":[],"updated":1783746993997,"link":null,"locked":false,"id":"rEGS6AJIGf5wAUpvaPQwU","type":"rectangle","x":-538.3191586396724,"y":1892.4635059217471,"width":736.5336713085208,"height":273.4002107598076,"strokeColor":"#60A5FA","backgroundColor":"#DBEAFE","roundness":{"type":3},"version":144,"index":"b6c"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["Xb7DGimhnihPIHQeGRS-O"],"frameId":null,"seed":303328231,"versionNonce":1652315783,"isDeleted":false,"boundElements":[],"updated":1783746993997,"link":null,"locked":false,"id":"yYeey9bnkG0lLObhMQkY_","type":"text","x":-518.3191586396724,"y":1906.4635059217471,"width":130,"height":16.25,"strokeColor":"#1D4ED8","backgroundColor":"transparent","roundness":null,"text":"Candidate","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":105,"index":"b6d"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["Xb7DGimhnihPIHQeGRS-O"],"frameId":null,"seed":478959367,"versionNonce":2044587431,"isDeleted":false,"boundElements":[],"updated":1783746993997,"link":null,"locked":false,"id":"Uk-C1izG6q_sCmYFDy4Cd","type":"text","x":-518.3191586396724,"y":1930.4635059217471,"width":680,"height":187.5,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"With 100K workflows and 1M runs/day, what does that imply for QPS and concurrency?\n\nRoughly ~10 new workflow starts/sec on average.\n\n• Baseline ingest ≈ 10 QPS\n• Peak ≈ 100 QPS (10× burst)\n• If runs average ~1 min → ~600 concurrent\n• At peak, design toward up to ~60K concurrent\n\nWe must account for disk I/O, concurrency control, and reliability under load.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"With 100K workflows and 1M runs/day, what does that imply for QPS and concurrency?\n\nRoughly ~10 new workflow starts/sec on average.\n\n• Baseline ingest ≈ 10 QPS\n• Peak ≈ 100 QPS (10× burst)\n• If runs average ~1 min → ~600 concurrent\n• At peak, design toward up to ~60K concurrent\n\nWe must account for disk I/O, concurrency control, and reliability under load.","autoResize":false,"lineHeight":1.25,"version":108,"index":"b6e"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["_dw-PWBMa0LRu1mlDo4tB"],"frameId":null,"seed":1662639655,"versionNonce":1530896583,"isDeleted":false,"boundElements":[],"updated":1783746993997,"link":null,"locked":false,"id":"Thfp3RC4wRIzYngJM99iF","type":"ellipse","x":-594.3191586396724,"y":2221.213505921747,"width":40,"height":40,"strokeColor":"#3B82F6","backgroundColor":"#3B82F6","roundness":null,"version":105,"index":"b6f"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["_dw-PWBMa0LRu1mlDo4tB"],"frameId":null,"seed":145326407,"versionNonce":138276839,"isDeleted":false,"boundElements":[],"updated":1783746993997,"link":null,"locked":false,"id":"BkUOIFGoVr2Fgzr2fbm4T","type":"text","x":-583.3191586396724,"y":2231.213505921747,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"C","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"C","autoResize":true,"lineHeight":1.25,"version":105,"index":"b6g"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["_dw-PWBMa0LRu1mlDo4tB"],"frameId":null,"seed":513261671,"versionNonce":451238663,"isDeleted":false,"boundElements":[],"updated":1783746993997,"link":null,"locked":false,"id":"pbKnEGkWPcunX3Q4UJM1m","type":"rectangle","x":-538.3191586396724,"y":2217.213505921747,"width":718.0209855115195,"height":202.3598732090443,"strokeColor":"#60A5FA","backgrou