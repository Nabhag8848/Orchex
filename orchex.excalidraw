      "link": null,
      "locked": false,
      "type": "text",
      "id": "IT3z6qADvb_cXRDJLzDn6",
      "x": 2265.4664695256834,
      "y": 5384.327546286774,
      "width": 637,
      "height": 16.25,
      "strokeColor": "#64748B",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "Blue = Candidate  ·  Green = Interviewer  ·  Own the core when the product is the workflow builder",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Blue = Candidate  ·  Green = Interviewer  ·  Own the core when the product is the workflow builder",
      "autoResize": true,
      "lineHeight": 1.25,
      "version": 81,
      "index": "b9e"
    },
    {
