e,"boundElements":[],"updated":1784708679955,"link":null,"locked":false,"type":"rectangle","id":"Gk3aB_RsMTq35W_iaJB3E","x":-5912.800993484607,"y":9743.602666971017,"width":760,"height":303.75,"strokeColor":"#60A5FA","backgroundColor":"#DBEAFE","roundness":{"type":3},"version":337,"index":"c0HV"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["oanVBJFd_4wqbYTTexnlg"],"frameId":null,"seed":1715933805,"versionNonce":1483211949,"isDeleted":false,"boundElements":[],"updated":1784708679955,"link":null,"locked":false,"type":"text","id":"fZkG1tAQaH2B9C9l5hRI6","x":-5892.800993484607,"y":9757.602666971017,"width":130,"height":16.25,"strokeColor":"#1D4ED8","backgroundColor":"transparent","roundness":null,"text":"Candidate","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":337,"index":"c0HW"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["oanVBJFd_4wqbYTTexnlg"],"frameId":null,"seed":301219021,"versionNonce":1874650893,"isDeleted":false,"boundElements":[],"updated":1784708679955,"link":null,"locked":false,"type":"text","id":"vB_n-qqjmC0dSJgGQNrVB","x":-5892.800993484607,"y":9781.602666971017,"width":720,"height":243.75,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"Pros:\n\u2022 Almost no custom orchestrator to build\n\u2022 Built-in retries, branching, timeouts, visual console\n\u2022 Great if you\u2019re already deep on AWS\n\u2022 Fast for internal tools / moderate volume\n\nCons:\n\u2022 You don\u2019t own the execution core \u2014 weak if workflow IS the product\n\u2022 Cost grows with many fine-grained state transitions\n\u2022 Lock-in; hard to self-host or go multi-cloud\n\u2022 Custom semantics (our error envelopes, resume UX, traces) get awkward\n\nUse when: internal tool + AWS-native stack.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Pros:\n\u2022 Almost no custom orchestrator to build\n\u2022 Built-in retries, branching, timeouts, visual console\n\u2022 Great if you\u2019re already deep on AWS\n\u2022 Fast for internal tools / moderate volume\n\nCons:\n\u2022 You don\u2019t own the execution core \u2014 weak if workflow IS the product\n\u2022 Cost grows with many fine-grained state transitions\n\u2022 Lock-in; hard to self-host or go multi-cloud\n\u2022 Custom semantics (our error envelopes, resume UX, traces) get awkward\n\nUse when: internal tool + AWS-native stack.","autoResize":false,"lineHeight":1.25,"version":337,"index":"c0HX"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"seed":2001541933,"versionNonce":1661369709,"isDeleted":false,"boundElements":[],"updated":1784708679955,"link":null,"locked":false,"type":"rectangle","id":"hqItonRfZqBngVpy9ngmR","x":-5968.800993484608,"y":10075.352666971017,"width":220,"height":42,"strokeColor":"#7C3AED","backgroundColor":"#7C3AED","roundness":{"type":3},"version":337,"index":"c0HY"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"seed":1320889741,"versionNonce":965625805,"isDeleted":false,"boundElements":[],"updated":1784708679955,"link":null,"locked":false,"type":"text","id":"9eFK8S-dNDrcM6PaH5333","x":-5952.800993484607,"y":10083.352666971017,"width":180,"height":22.5,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"3 \u00b7 Temporal","fontSize":18,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"3 \u00b7 Temporal","autoResize":true,"lineHeight":1.25,"version":337,"index":"c0HZ"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["nUL_rrQrywfeK46j0p847"],"frameId":nu