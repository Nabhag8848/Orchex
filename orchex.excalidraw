"updated":1784708679958,"link":null,"locked":false,"type":"ellipse","id":"RxVAruV0HG3-AwPyqVdZF","x":-5968.800993484608,"y":11886.102666971017,"width":40,"height":40,"strokeColor":"#3B82F6","backgroundColor":"#3B82F6","roundness":null,"version":337,"index":"c0IN"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["zRYJTVOByjgn-Cb7zzLeM"],"frameId":null,"seed":159329965,"versionNonce":1653600493,"isDeleted":false,"boundElements":[],"updated":1784708679958,"link":null,"locked":false,"type":"text","id":"BVXXW6MnGomHwm1AKVAX2","x":-5957.800993484607,"y":11896.102666971017,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"C","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"C","autoResize":true,"lineHeight":1.25,"version":337,"index":"c0IO"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["zRYJTVOByjgn-Cb7zzLeM"],"frameId":null,"seed":140431629,"versionNonce":2124237645,"isDeleted":false,"boundElements":[],"updated":1784708679958,"link":null,"locked":false,"type":"rectangle","id":"j5byFf7K3hraQm9GlI3CH","x":-5912.800993484607,"y":11882.102666971017,"width":760,"height":369.25,"strokeColor":"#60A5FA","backgroundColor":"#DBEAFE","roundness":{"type":3},"version":337,"index":"c0IP"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["zRYJTVOByjgn-Cb7zzLeM"],"frameId":null,"seed":601565037,"versionNonce":953178541,"isDeleted":false,"boundElements":[],"updated":1784708679958,"link":null,"locked":false,"type":"text","id":"GamuZENYisPU92-Q726Rc","x":-5892.800993484607,"y":11896.102666971017,"width":130,"height":16.25,"strokeColor":"#1D4ED8","backgroundColor":"transparent","roundness":null,"text":"Candidate","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":337,"index":"c0IQ"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["zRYJTVOByjgn-Cb7zzLeM"],"frameId":null,"seed":238924237,"versionNonce":710056973,"isDeleted":false,"boundElements":[],"updated":1784708679958,"link":null,"locked":false,"type":"text","id":"GwCJF7IbwjPVh_4ogVF-A","x":-5892.800993484607,"y":11920.102666971017,"width":720,"height":281.25,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"Decision rule:\n\n0) Legacy AWS, already on SWF\n   \u2192 stay on SWF or migrate toward Step Functions\n\n1) Workflow builder is the CORE PRODUCT\n   \u2192 Queues + Workers (+ Durable Lambda for function isolation only)\n\n2) Internal tool, already on AWS, moderate needs\n   \u2192 AWS Step Functions (not SWF for new work)\n\n3) Internal tool, need strong long-running execution\n   \u2192 Temporal\n\nOrchex = case (1). Own orchestration; rent sandbox.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Decision rule:\n\n0) Legacy AWS, already on SWF\n   \u2192 stay on SWF or migrate toward Step Functions\n\n1) Workflow builder is the CORE PRODUCT\n   \u2192 Queues + Workers (+ Durable Lambda for function isolation only)\n\n2) Internal tool, already on AWS, moderate needs\n   \u2192 AWS Step Functions (not SWF for new work)\n\n3) Internal tool, need strong long-running execution\n   \u2192 Temporal\n\nOrchex = case (1). Own orchestration; rent sandbox.","autoResize":false,"lineHeight":1.25,"version":337,"index":"c0IR"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["xmdBQRN8s_i4AmdUU_1-9"],"frameId":null,"seed":1956638765,"versionNonce":186487405,"isDeleted":false,"boundElements":[],"updated":1784708679958,"link":null,"locked":false,"type":"ellipse","id":"E2ODmK2b5xw37ECBlq3xH","x":-4984.800993484607,"y":12187.102666971017,"width":40,"height":40,"strokeColor":"#22C55E","backgroundColor":"#22C55E","roundness":null,"version":337,"index":"c0IS"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["xmdBQRN8s_i4AmdUU_1-9"],"frameId":null,"seed":619405965,"versionNonce":1476050125,"isDeleted":false,"boundElements":[],"updated":1784708679958,"link":null,"locked":false,"type":"text","id":"eiV6ULqAzhAzHSfPNDxxW","x":-4973.800993484607,"y":12197.102666971017,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"I","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"I","autoResize":true,"lineHeight":1.25,"version":337,"index":"c0IT"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["xmdBQRN8s_i4AmdUU_1-9"],"frameId":null,"seed":1943636205,"versionNonce":948149037,"isDeleted":false,"boundElements":[],"updated":1784708679958,"link":null,"locked":false,"type":"rectangle","id":"Nhf_TkaljLUC8OjbPDE69","x":-5704.800993484607,"y":12183.102666971017,"width":760,"height":124.25,"strokeColor":"#4ADE80","backgroundColor":"#DCFCE7","roundness":{"type":3},"version":337,"index":"c0IU"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["xmdBQRN8s_i4AmdUU_1-9"],"frameId":null,"seed":1660150605,"versionNonce":622964109,"isDeleted":false,"boundElements":[],"updated":1784708679958,"link":null,"locked":false,"type":"text","id":"CM2H5iWYetbLF3iyoK436","x":-5684.800993484607,"y":12197.102666971017,"width":130,"height":16.25,"strokeColor":"#15803D","backgroundColor":"transparent","roundness":null,"text":"Interviewer","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Interviewer","autoResize":true,"lineHeight":1.25,"version":337,"index":"c0IV"},{"angle":0,"fil