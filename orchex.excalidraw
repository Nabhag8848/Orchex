    {
      "angle": 0,
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "vl2ZVr3o1ZjhwygDy3_Xq"
      ],
      "frameId": null,
      "seed": 807746560,
      "versionNonce": 1759937536,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1783934932908,
