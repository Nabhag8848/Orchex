      "originalText": "{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"type\": \"integration\",\n  \"category\": \"action\",\n  \"display_name\": \"Integration Action\",\n  \"config_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"provider\", \"action\"],\n    \"properties\": {\n      \"provider\": {\n        \"const\": \"composio\"\n      },\n      \"action\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 256,\n        \"pattern\": \"^[A-Z][A-Z0-9_]*$\",\n        \"description\": \"Composio action id, e.g. GITHUB_CREATE_ISSUE\"\n      },\n      \"params\": {\n        \"type\": \"object\",\n        \"description\": \"Action params; may include templates over input.data\",\n        \"additionalProperties\": {\n          \"type\": [\"object\", \"array\", \"string\", \"number\", \"boolean\", \"null\"]\n        }\n      },\n      \"timeout_ms\": {\n        \"type\": \"integer\",\n        \"minimum\": 1,\n        \"maximum\": 300000,\n        \"default\": 30000\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"input_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"output_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": \"object\",\n        \"required\": [\"action\", \"result\"],\n        \"properties\": {\n          \"action\": {\n            \"type\": \"string\",\n            \"minLength\": 1,\n            \"maxLength\": 256,\n            \"pattern\": \"^[A-Z][A-Z0-9_]*$\"\n          },\n          \"result\": {\n            \"type\": [\"object\", \"array\", \"string\", \"number\", \"boolean\", \"null\"]\n          }\n        },\n        \"additionalProperties\": false\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"error_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"type\", \"code\", \"message\", \"retryable\"],\n    \"properties\": {\n      \"type\": {\n        \"type\": \"string\",\n        \"enum\": [\"validation\", \"operation\", \"auth\", \"api\", \"timeout\", \"rate_limit\", \"internal\"],\n        \"description\": \"Error class used for UI routing and retry policy\"\n      },\n      \"code\": {\n        \"type\": \"string\",\n        \"enum\": [\n          \"INVALID_INPUT\",\n          \"INVALID_CONFIG\",\n          \"AUTH_EXPIRED\",\n          \"ACTION_FAILED\",\n          \"TIMEOUT\",\n          \"NETWORK_ERROR\",\n          \"RATE_LIMITED\",\n          \"INTERNAL_ERROR\"\n        ]\n      },\n      \"message\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 512,\n        \"description\": \"Short user-facing summary\"\n      },\n      \"description\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 2048,\n        \"description\": \"Optional remediation guidance shown in run history\"\n      },\n      \"retryable\": {\n        \"type\": \"boolean\"\n      },\n      \"retry_after_ms\": {\n        \"type\": \"integer\",\n        \"minimum\": 0,\n        \"maximum\": 3600000,\n        \"description\": \"Suggested delay before retry (e.g. rate limits / auth refresh)\"\n      },\n      \"http_status\": {\n        \"type\": \"integer\",\n        \"enum\": [\n          100, 101, 102, 103,\n          200, 201, 202, 203, 204, 205, 206, 207, 208, 226,\n          300, 301, 302, 303, 304, 305, 307, 308,\n          400, 401, 402, 403, 404, 405, 406, 407, 408, 409, 410,\n          411, 412, 413, 414, 415, 416, 417, 418, 421, 422, 423,\n          424, 425, 426, 428, 429, 431, 451,\n          500, 501, 502, 503, 504, 505, 506, 507, 508, 510, 511\n        ]\n      },\n      \"details\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"parameter\": {