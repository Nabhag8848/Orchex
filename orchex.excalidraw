e":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Interviewer","autoResize":true,"lineHeight":1.25,"version":121,"index":"c1GR"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["gKfTECVvAIlQ2Yqs-N6dv"],"frameId":null,"seed":567171206,"versionNonce":77700102,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"id":"dmCGY8iz6AtWouAMFk132","type":"text","x":-12763.604142570757,"y":29139.72452113669,"width":680,"height":18.75,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"We should be able to restart a workflow from where it failed — resume-from-failure is a hard requirement.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"We should be able to restart a workflow from where it failed — resume-from-failure is a hard requirement.","autoResize":false,"lineHeight":1.25,"version":121,"index":"c1GS"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["ZNNUO6LOj9fMWsYDS2gPr"],"frameId":null,"seed":951932870,"versionNonce":1155174234,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"id":"DrtiLVFou0xYwz3ZyOL2k","type":"ellipse","x":-13083.604142570757,"y":29202.47452113669,"width":40,"height":40,"strokeColor":"#3B82F6","backgroundColor":"#3B82F6","roundness":null,"version":123,"index":"c1GT"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["ZNNUO6LOj9fMWsYDS2gPr"],"frameId":null,"seed":1879731974,"versionNonce":2002529094,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"id":"svgIB07tz9y_mfBx-g8gi","type":"text","x":-13072.604142570757,"y":29212.47452113669,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"C","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"C","autoResize":true,"lineHeight":1.25,"version":123,"index":"c1GU"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["ZNNUO6LOj9fMWsYDS2gPr"],"frameId":null,"seed":1144168006,"versionNonce":1547932698,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"id":"EAbJZ-0I1Xd0nzb1d3TaC","type":"rectangle","x":-13027.604142570757,"y":29198.47452113669,"width":736.5336713085208,"height":273.4002107598076,"strokeColor":"#60A5FA","backgroundColor":"#DBEAFE","roundness":{"type":3},"version":162,"index":"c1GV"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["ZNNUO6LOj9fMWsYDS2gPr"],"frameId":null,"seed":437446022,"versionNonce":713216646,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"id":"_eAoBnDXPKBx-msXJbp8P","type":"text","x":-13007.604142570757,"y":29212.47452113669,"width":130,"height":16.25,"strokeColor":"#1D4ED8","backgroundColor":"transparent","roundness":null,"text":"Candidate","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":123,"index":"c1GW"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["ZNNUO6LOj9fMWsYDS2gPr"],"frameId":null,"seed":854082758,"versionNonce":1370357978,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"id":"Gpr7LlS-hWsvXk4L6eKSH","type":"text","x":-13007.604142570757,"y":29236.47452113669,"width":680,"height":187.5,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"With 100K workflows and 1M runs/day, what does that imply for QPS and concurrency?\n\nRoughly ~10 new workflow starts/sec on average.\n\n• Baseline ingest ≈ 10 QPS\n• Peak ≈ 100 QPS (10× burst)\n• If runs average ~1 min → ~600 concurrent (~6K at peak)\n• Capacity target ~60K concurrent for longer-running nodes — not from the 1-min math\n\nWe must account for disk I/O, concurrency control, and reliability under load.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"With 100K workflows and 1M runs/day, what does that imply for QPS and concurrency?\n\nRoughly ~10 new workflow starts/sec on average.\n\n• Baseline ingest ≈ 10 QPS\n• Peak ≈ 100 QPS (10× burst)\n• If runs average ~1 min → ~600 concurrent (~6K at peak)\n• Capacity target ~60K concurrent for longer-running nodes — not from the 1-min math\n\nWe must account for disk I/O, concurrency control, and reliability under load.","autoResize":false,"lineHeight":1.25,"version":127,"index":"c1GX"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["LWfxECyiiJ1nc8e0qd4GE"],"frameId":null,"seed":542096390,"versionNonce":1758630342,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"id":"0LoiEvkZ5RL7hLd4k9Ed-","type":"ellipse","x":-13083.604142570757,"y":29527.22452113669,"width":40,"height":40,"strokeColor":"#3B82F6","backgroundColor":"#3B82F6","roundness":null,"version":123,"index":"c1GY"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["LWfxECyiiJ1nc8e0qd4GE"],"frameId":null,"seed":944130886,"versionNonce":816633242,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"id":"dGOqSfbj_NJZd7pqXwDAe","type":"text","x":-13072.604142570757,"y":29537.22452113669,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"C","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"C","autoResize":true,"lineHeight":1.25,"version":