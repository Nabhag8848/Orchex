s":["y9n0N09Y9iVchKDOS8h7-"],"frameId":null,"seed":581745664,"versionNonce":1350712320,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"text","id":"ZQDEQvnMjmeMWdEO_kyW-","x":-1985.219599435662,"y":2524.4996901427708,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"C","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"C","autoResize":true,"lineHeight":1.25,"version":322,"index":"bIo"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["y9n0N09Y9iVchKDOS8h7-"],"frameId":null,"seed":632634368,"versionNonce":2094709760,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"rectangle","id":"UMOdzZmtFTG12-9l5UPJa","x":-1940.219599435662,"y":2510.4996901427708,"width":760,"height":303.75,"strokeColor":"#60A5FA","backgroundColor":"#DBEAFE","roundness":{"type":3},"version":322,"index":"bIp"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["y9n0N09Y9iVchKDOS8h7-"],"frameId":null,"seed":867023872,"versionNonce":170081280,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"text","id":"iU2XfwuOm8kAAs_78dwMc","x":-1920.219599435662,"y":2524.4996901427708,"width":130,"height":16.25,"strokeColor":"#1D4ED8","backgroundColor":"transparent","roundness":null,"text":"Candidate","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":322,"index":"bIq"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["y9n0N09Y9iVchKDOS8h7-"],"frameId":null,"seed":1855339520,"versionNonce":1515961344,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"text","id":"V14gQkvW8Jur9zfq4oDK8","x":-1920.219599435662,"y":2548.4996901427708,"width":720,"height":187.5,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"Pros:\n• You own the core — right choice when workflow builder IS the product\n• Full control over DAG rules, error schemas, resume, observability\n• Lambda/E2B can be swappable sandbox adapter, not the brain, more extensible\n• Fits our scale path (1M runs/day) with worker autoscaling\n\nCons:\n• You must build Temporal-like internals (simpler cousin): retries, idempotency, poison messages\n• More engineering than Step Functions for an internal tool\n• Easy to under-build durability if careless.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Pros:\n• You own the core — right choice when workflow builder IS the product\n• Full control over DAG rules, error schemas, resume, observability\n• Lambda/E2B can be swappable sandbox adapter, not the brain, more extensible\n• Fits our scale path (1M runs/day) with worker autoscaling\n\nCons:\n• You must build Temporal-like internals (simpler cousin): retries, idempotency, poison messages\n• More engineering than Step Functions for an internal tool\n• Easy to under-build durability if careless.","autoResize":false,"lineHeight":1.25,"version":358,"index":"bIr"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"seed":946781184,"versionNonce":260324352,"isDeleted":false,"boundElements":[],"updated":1783935467643,"link":null,"locked":false,"type":"rectangle","id":"AqFH_KmD3t9fmqaR8aTQP","x":-1996.219599435662,"y":2842.2496901427708,"width":220,"height":42,"strokeColor":"#0F172A","backgroundColor":"#0F172A","roundness":{"type":3},"version":322,"index":"bIs"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"seed":859257856,"vers