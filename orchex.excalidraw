      "text": "• Core product (like Sim / Gumloop / Orchex)",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• Core product (like Sim / Gumloop / Orchex)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "IPXXSilc7tw7ycAT2Sv9K",
