"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["icI3I3fTUBs_wOxart9ZY"],"frameId":null,"seed":1162897965,"versionNonce":1702530157,"isDeleted":false,"boundElements":[],"updated":1784708679957,"link":null,"locked":false,"type":"text","id":"TyHbLcmvarWs5YHWp9XZ8","x":-5957.800993484607,"y":11409.602666971017,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"C","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"C","autoResize":true,"lineHeight":1.25,"version":337,"index":"c0IC"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["icI3I3fTUBs_wOxart9ZY"],"frameId":null,"seed":1031576717,"versionNonce":279475917,"isDeleted":false,"boundElements":[],"updated":1784708679957,"link":null,"locked":false,"type":"rectangle","id":"y_YlEiWfDzqTHEzodEz8n","x":-5912.800993484607,"y":11395.602666971017,"width":760,"height":303.75,"strokeColor":"#60A5FA","backgroundColor":"#DBEAFE","roundness":{"type":3},"version":337,"index":"c0ID"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["icI3I3fTUBs_wOxart9ZY"],"frameId":null,"seed":439583469,"versionNonce":1198134573,"isDeleted":false,"boundElements":[],"updated":1784708679957,"link":null,"locked":false,"type":"text","id":"U5vn0181MZRXE1ShoUj_C","x":-5892.800993484607,"y":11409.602666971017,"width":130,"height":16.25,"strokeColor":"#1D4ED8","backgroundColor":"transparent","roundness":null,"text":"Candidate","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":337,"index":"c0IE"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["icI3I3fTUBs_wOxart9ZY"],"frameId":null,"seed":1610521933,"versionNonce":1160308621,"isDeleted":false,"boundElements":[],"updated":1784708679957,"link":null,"locked":false,"type":"text","id":"SDSE1NOiczbPZEjiAnF9Z","x":-5892.800993484607,"y":11433.602666971017,"width":720,"height":187.5,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"Pros:\n\u2022 You own the core \u2014 right choice when workflow builder IS the product\n\u2022 Full control over DAG rules, error schemas, resume, observability\n\u2022 Lambda/E2B can be swappable sandbox adapter, not the brain, more extensible\n\u2022 Fits our scale path (1M runs/day) with worker autoscaling\n\nCons:\n\u2022 You must build Temporal-like internals (simpler cousin): retries, idempotency, poison messages\n\u2022 More engineering than Step Functions for an internal tool\n\u2022 Easy to under-build durability if careless.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Pros:\n\u2022 You own the core \u2014 right choice when workflow builder IS the product\n\u2022 Full control over DAG rules, error schemas, resume, observability\n\u2022 Lambda/E2B can be swappable sandbox adapter, not the brain, more extensible\n\u2022 Fits our scale path (1M runs/day) with worker autoscaling\n\nCons:\n\u2022 You must build Temporal-like internals (simpler cousin): retries, idempotency, poison messages\n\u2022 More engineering than Step Functions for an internal tool\n\u2022 Easy to under-build durability if careless.","autoResize":false,"lineHeight":1.25,"version":373,"index":"c0IF"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"seed":1178037165,"versionNonce":471756269,"isDeleted":false,"boundElements":[],"updated":1784708679958,"link":null,"locked":false,"type":"rectangle","id":"OT8B09rt9eCPemv1Y2gfi","x":-5968.800993484608,"y":11727.352666971017,"width":220,"height":42,"strokeColor":"#0F172A","backgroundColor":"#0F172A","roundness":{"type"