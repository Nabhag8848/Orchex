    {
      "angle": 0,
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "UGY2Gy0gz9F60R7zMX96N"
      ],
      "frameId": null,
      "seed": 2047149056,
      "versionNonce": 1543420928,
