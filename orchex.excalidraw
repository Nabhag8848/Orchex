      "locked": false,
      "type": "text",
      "id": "03bS1DSWbgp2baCIlrtIn",
      "x": 2354.516065537358,
      "y": 4295.815314095467,
      "width": 720,
      "height": 187.5,
      "strokeColor": "#0F172A",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "Core concepts:\n• Queue — job per node step\n• Worker — orchestrates: load run, pick executor, checkpoint, enqueue next\n• Executors — API / Conditional / Function / Integration / Response\n• Durable Lambda (or similar sandbox) — ONLY for untrusted Function code isolation\n• Postgres — workflow_runs, current_node_id, error, context\n\nFlow:\nenqueue execute(node) → success → checkpoint → enqueue successor(s)\nfailure → store error → resume later from that node",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core concepts:\n• Queue — job per node step\n• Worker — orchestrates: load run, pick executor, checkpoint, enqueue next\n• Executors — API / Conditional / Function / Integration / Response\n• Durable Lambda (or similar sandbox) — ONLY for untrusted Function code isolation\n• Postgres — workflow_runs, current_node_id, error, context\n\nFlow:\nenqueue execute(node) → success → checkpoint → enqueue successor(s)\nfailure → store error → resume later from that node",
      "autoResize": false,
      "lineHeight": 1.25,
      "version": 201,
      "index": "bGq"
    },
