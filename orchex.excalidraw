    {
      "angle": 0,
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "CLOpOTEgdYsw4bPTvlGhJ"
      ],
      "frameId": null,
      "seed": 723205120,
      "versionNonce": 302038016,
      "isDeleted": false,
      "boundElements": [],
