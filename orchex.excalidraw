6,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25},{"id":"JSSFAGTqK7Io4u80RUq90","angle":0,"strokeColor":"#2f9e44","backgroundColor":"#ebfbee","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":1690996038,"versionNonce":307250330,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"index":"c1Xj","version":103,"type":"rectangle","x":4832.923784927247,"y":28551.084759682715,"width":2600,"height":420},{"id":"PsNbev2k8gswrXcd2IbHL","angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":1607791750,"versionNonce":758606342,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"index":"c1Xk","version":102,"type":"text","x":4862.923784927247,"y":28576.084759682715,"width":756.8000000000001,"height":40,"text":"3 — The decision: Amazon RDS for PostgreSQL","originalText":"3 — The decision: Amazon RDS for PostgreSQL","fontSize":32,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25},{"id":"f-aQkAcOjkBzOOjTuExTF","angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":865104838,"versionNonce":1943052634,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"index":"c1Xl","version":102,"type":"text","x":4862.923784927247,"y":28631.084759682715,"width":2500,"height":157.5,"text":"1. Relational Postgres is mandatory — same-version FKs + uniqueness stay in the DB.\n2. AWS is home — SQS is already the queue; do not split clouds.\n3. Distributed SQL / sharding are premature — peak is ~1000 small txns/s, not “one machine is full.”\n4. Aurora is optional luxury — pay more for nicer HA later if needed.\n5. RDS is the cost/simplicity default that still speaks full PostgreSQL (and CDC later).\n\nLocked: one region · one writer · managed by AWS · planning size ~2 vCPU / 4 GB.","originalText":"1. Relational Postgres is mandatory — same-version FKs + uniqueness stay in the DB.\n2. AWS is home — SQS is already the queue; do not split clouds.\n3. Distributed SQL / sharding are premature — peak is ~1000 small txns/s, not “one machine is full.”\n4. Aurora is optional luxury — pay more for nicer HA later if needed.\n5. RDS is the cost/simplicity default that still speaks full PostgreSQL (and CDC later).\n\nLocked: one region · one writer · managed by AWS · planning size ~2 vCPU / 4 GB.","fontSize":18,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25},{"id":"igIU_v3ZUNM5zZT31X-F0","angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":1511656198,"versionNonce":1745369414,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"index":"c1Xm","version":102,"type":"text","x":4832.923784927247,"y":29011.084759682715,"width":528,"height":40,"text":"4 — Where RDS sits in the flow","originalText":"4 — Where RDS sits in the flow","fontSize":32,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25},{"id":"Zt7fhmZM5oRvzUmLVnWew","angle":0,"strokeColor":"#1e1e1e","backgroundColor":"#ffec99","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":32422470,"versionNonce":648504858,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"index":"c1Xn","version":102