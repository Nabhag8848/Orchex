      "originalText": "{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"type\": \"conditional\",\n  \"category\": \"logic\",\n  \"display_name\": \"Conditional\",\n  \"config_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"expression\"],\n    \"properties\": {\n      \"expression\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 4096,\n        \"description\": \"Boolean expression over input.data, e.g. data.payload.status == 200\"\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"input_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"output_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": \"object\",\n        \"required\": [\"branch\"],\n        \"properties\": {\n          \"branch\": {\n            \"type\": \"string\",\n            \"enum\": [\"true\", \"false\"]\n          }\n        },\n        \"additionalProperties\": true\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"error_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"type\", \"code\", \"message\", \"retryable\"],\n    \"properties\": {\n      \"type\": {\n        \"type\": \"string\",\n        \"enum\": [\"validation\", \"operation\", \"internal\"],\n        \"description\": \"Error class used for UI routing and retry policy\"\n      },\n      \"code\": {\n        \"type\": \"string\",\n        \"enum\": [\"INVALID_INPUT\", \"EXPRESSION_ERROR\", \"INTERNAL_ERROR\"]\n      },\n      \"message\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 512,\n        \"description\": \"Short user-facing summary\"\n      },\n      \"description\": {\n        \"type\": \"string\",\n       