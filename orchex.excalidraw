    {
      "angle": 0,
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "NC9Q23FyrFJ8z-ldK4iI7"
      ],
      "frameId": null,
      "seed": 2056258560,
      "versionNonce": 1411169280,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1783934588389,
      "link": null,
      "locked": false,
      "type": "text",
      "id": "bvaLieQGxlSHdgCBp1TKD",
      "x": 2549.4664695256834,
      "y": 2739.827546286774,
      "width": 720,
      "height": 243.75,
      "strokeColor": "#0F172A",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "Pros:\n• Almost no custom orchestrator to build\n• Built-in retries, branching, timeouts, visual console\n• Great if you’re already deep on AWS\n• Fast for internal tools / moderate volume\n\nCons:\n• You don’t own the execution core — weak if workflow IS the product\n• Cost grows with many fine-grained state transitions\n• Lock-in; hard to self-host or go multi-cloud\n• Custom semantics (our error envelopes, resume UX, traces) get awkward\n\nUse when: internal tool + AWS-native stack.",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pros:\n• Almost no custom orchestrator to build\n• Built-in retries, branching, timeouts, visual console\n• Great if you’re already deep on AWS\n• Fast for internal tools / moderate volume\n\nCons:\n• You don’t own the execution core — weak if workflow IS the product\n• Cost grows with many fine-grained state transitions\n• Lock-in; hard to self-host or go multi-cloud\n• Custom semantics (our error envelopes, resume UX, traces) get awkward\n\nUse when: internal tool + AWS-native stack.",
      "autoResize": false,
      "lineHeight": 1.25,
      "version": 81,
      "index": "b8Z"
    },
