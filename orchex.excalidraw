679984,"link":null,"locked":false,"version":95,"text":"manual Retry \u2192 counter resets to 1 \u2192 fresh outbox row \u2192 fresh message","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"manual Retry \u2192 counter resets to 1 \u2192 fresh outbox row \u2192 fresh message","autoResize":true,"lineHeight":1.25,"index":"c0Rd"},{"id":"HSpqqVoH6P5AzhxhKSLJ-","type":"text","x":9725.718824618798,"y":10900.071511575481,"width":336.4,"height":25,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":1970855405,"versionNonce":1166487597,"isDeleted":false,"boundElements":[],"updated":1784708679984,"link":null,"locked":false,"version":95,"text":"How a retry physically works:","fontSize":20,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"How a retry physically works:","autoResize":true,"lineHeight":1.25,"index":"c0Re"},{"id":"-RRBz7I04QTsK8YuEdByX","type":"text","x":9725.718824618798,"y":10945.071511575481,"width":443.7,"height":106.25,"angle":0,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":2145425485,"versionNonce":1458217613,"isDeleted":false,"boundElements":[],"updated":1784708679984,"link":null,"locked":false,"version":95,"text":"same transaction as any checkpoint \u2014\nbump attempt counter + insert outbox row with\navailable_at = now() + backoff.\nRelay ignores rows that aren't due yet.\nThe retry is a brand-new message.","fontSize":17,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"same transaction as any checkpoint \u2014\nbump attempt counter + insert outbox row with\navailable_at = now() + backoff.\nRelay ignores rows that aren't due yet.\nThe retry is a brand-new message.","autoResize":true,"lineHeight":1.25,"index":"c0Rf"},{"id":"Dz69sjMtg91gS53eebIVL","type":"text","x":7605.718824618798,"y":11500.071511575481,"width":2829.24,"height":22.5,"angle":0,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":773981869,"versionNonce":602982637,"isDeleted":false,"boundElements":[],"updated":1784708679984,"link":null,"locked":false,"version":95,"text":"Policy: 3 attempts total \u00b7 waits 10s / 40s \u00b7 \u00b125% jitter so a thousand runs don't retry in the same second \u00b7 RATE_LIMITED respects retry_after_ms (whichever wait is longer) \u00b7 non-retryable errors (bad config, HTTP 400, expired auth) skip all of this and fail immediately.","fontSize":18,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Policy: 3 attempts total \u00b7 waits 10s / 40s \u00b7 \u00b125% jitter so a thousand runs don't retry in the same second \u00b7 RATE_LIMITED respects retry_after_ms (whichever wait is longer) \u00b7 non-retryable errors (bad config, HTTP 400, expired auth) skip all of this and fail immediately.","autoResize":true,"lineHeight":1.25,"index":"c0Rg"},{"id":"uLGRfPuJnJA-jInoY9Y0B","type":"rectangle","x":7545.718824618798,"y":11700.071511575481,"width":2760,"height":760,"angle":0,"strokeColor":"#adb5bd","backgroundColor":"#f8f9fa","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":1122412813,"versionNonce":237183821,"isDeleted":false,"boundElements":[],"updated":1784708679984,"link":null,"locked":false,"version":95,"index":"c0Rh"},{"id":"xyQxYaJSj1fqvnhMgWHv0","type":"text","x":7575.718824618798,"y":11725.071511575481,"width":835.1999999999999,"height":40,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":