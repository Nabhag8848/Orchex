      "link": null,
      "locked": false,
      "type": "text",
      "id": "hG-KyfirQ_7qHapUM0CAw",
      "x": -1920.219599435662,
      "y": 575.7496901427708,
      "width": 720,
      "height": 150,
      "strokeColor": "#0F172A",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "Core concepts:\n• State machine — your workflow definition (ASL JSON)\n• States — Task, Choice, Wait, Parallel, Map, Succeed/Fail\n• Task state — usually invokes Lambda / ECS / HTTP\n• Transitions — AWS stores progress and retries\n• Execution history — managed run log on AWS side\n\nYou define the graph; AWS runs and persists it.",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core concepts:\n• State machine — your workflow definition (ASL JSON)\n• States — Task, Choice, Wait, Parallel, Map, Succeed/Fail\n• Task state — usually invokes Lambda / ECS / HTTP\n• Transitions — AWS stores progress and retries\n• Execution history — managed run log on AWS side\n\nYou define the graph; AWS runs and persists it.",
      "autoResize": false,
      "lineHeight": 1.25,
      "version": 322,
      "index": "bHz"
    },
