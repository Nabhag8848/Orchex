    {
      "angle": 0,
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "TStJr1SRk37XFPaDnk7Lt"
      ],
      "frameId": null,
      "seed": 1468662784,
      "versionNonce": 745913344,
      "isDeleted": true,
