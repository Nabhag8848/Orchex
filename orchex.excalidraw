index":"c1Ik"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["49784Bt3GN9Jm8w1KEl44"],"frameId":null,"seed":1415562566,"versionNonce":1845127322,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"tXkXd280MjB9b1NqbUxHo","x":-14409.504583366745,"y":31137.010705357716,"width":130,"height":16.25,"strokeColor":"#1D4ED8","backgroundColor":"transparent","roundness":null,"text":"Candidate","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":340,"index":"c1Il"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["49784Bt3GN9Jm8w1KEl44"],"frameId":null,"seed":402861190,"versionNonce":1404143110,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"YSZ9s9y3xBN1y9G3SoaDe","x":-14409.504583366745,"y":31161.010705357716,"width":720,"height":281.25,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"Decision rule:\n\n0) Legacy AWS, already on SWF\n   → stay on SWF or migrate toward Step Functions\n\n1) Workflow builder is the CORE PRODUCT\n   → Queues + Workers (+ Durable Lambda for function isolation only)\n\n2) Internal tool, already on AWS, moderate needs\n   → AWS Step Functions (not SWF for new work)\n\n3) Internal tool, need strong long-running execution\n   → Temporal\n\nOrchex = case (1). Own orchestration; rent sandbox.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Decision rule:\n\n0) Legacy AWS, already on SWF\n   → stay on SWF or migrate toward Step Functions\n\n1) Workflow builder is the CORE PRODUCT\n   → Queues + Workers (+ Durable Lambda for function isolation only)\n\n2) Internal tool, already on AWS, moderate needs\n   → AWS Step Functions (not SWF for new work)\n\n3) Internal tool, need strong long-running execution\n   → Temporal\n\nOrchex = case (1). Own orchestration; rent sandbox.","autoResize":false,"lineHeight":1.25,"version":340,"index":"c1Im"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["NF-AoYHKhbLmrpaBiZQ1D"],"frameId":null,"seed":959949766,"versionNonce":513164634,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"ellipse","id":"eCvGeJbg5O8kgLL51zmw8","x":-13501.504583366745,"y":31428.010705357716,"width":40,"height":40,"strokeColor":"#22C55E","backgroundColor":"#22C55E","roundness":null,"version":340,"index":"c1In"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["NF-AoYHKhbLmrpaBiZQ1D"],"frameId":null,"seed":370819846,"versionNonce":1893651782,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"text","id":"W6hege5XBWtT19GsOoXkh","x":-13490.504583366745,"y":31438.010705357716,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"I","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"I","autoResize":true,"lineHeight":1.25,"version":340,"index":"c1Io"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["NF-AoYHKhbLmrpaBiZQ1D"],"frameId":null,"seed":1093136966,"versionNonce":823691802,"isDeleted":false,"boundElements":[],"updated":1784789802835,"link":null,"locked":false,"type":"rectangle","id":"XKvsquXIoMxQ54zn8BIu1","x":-14221.504583366745,"y":31424.010705357716,"width":760,"height":124.25,"strokeColor":"#4ADE80","backgroundColor":"#DCFCE7","roundness":{"type":3},"version":340,"index":"c1Ip"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["NF-AoYHKhbLmrpaBiZQ1