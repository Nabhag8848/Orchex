      "width": 680,
      "height": 75,
      "strokeColor": "#0F172A",
      "backgroundColor": "transparent",
      "roundness": null,
      "text": "What consistency model do we need for logs and traces?\n\nEventual consistency is fine.\nA few milliseconds of delay in traces and logs is acceptable.",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What consistency model do we need for logs and traces?\n\nEventual consistency is fine.\nA few milliseconds of delay in traces and logs is acceptable.",
      "autoResize": false,
      "lineHeight": 1.25,
      "version": 108,
      "index": "b6o"
