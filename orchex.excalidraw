d2pvqV9","x":-1920.219599435662,"y":1679.7496901427708,"width":130,"height":16.25,"strokeColor":"#1D4ED8","backgroundColor":"transparent","roundness":null,"text":"Candidate","fontSize":13,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Candidate","autoResize":true,"lineHeight":1.25,"version":322,"index":"bIU"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["Gnbha8XBEgiuAv-Y2L0fJ"],"frameId":null,"seed":590035968,"versionNonce":336641024,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"text","id":"2GvbVH4mG0A-ezzhHG0ln","x":-1920.219599435662,"y":1703.7496901427708,"width":720,"height":243.75,"strokeColor":"#0F172A","backgroundColor":"transparent","roundness":null,"text":"Pros:\n• Excellent durability / resume / retries for long-running flows\n• Code-first workflows; strong failure semantics\n• You still own product UI, schemas, node types\n• Better “execution platform” than Step Functions if workflows are long/complex\n\nCons:\n• Real ops cost (Temporal Cloud or self-host cluster)\n• Learning curve (determinism, replay, versioning)\n• Overkill for simple short DAGs\n• Still not a full workflow-builder product — you build Orchex around it\n\nUse when: internal tool needing a serious long-running execution layer.","fontSize":15,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Pros:\n• Excellent durability / resume / retries for long-running flows\n• Code-first workflows; strong failure semantics\n• You still own product UI, schemas, node types\n• Better “execution platform” than Step Functions if workflows are long/complex\n\nCons:\n• Real ops cost (Temporal Cloud or self-host cluster)\n• Learning curve (determinism, replay, versioning)\n• Overkill for simple short DAGs\n• Still not a full workflow-builder product — you build Orchex around it\n\nUse when: internal tool needing a serious long-running execution layer.","autoResize":false,"lineHeight":1.25,"version":322,"index":"bIV"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"seed":308526080,"versionNonce":1251556352,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"rectangle","id":"lCkvE5ge_diAGIykSjhXJ","x":-1996.219599435662,"y":1997.4996901427708,"width":521.675177924522,"height":42,"strokeColor":"#E11D48","backgroundColor":"#E11D48","roundness":{"type":3},"version":331,"index":"bIW"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"seed":109853696,"versionNonce":470924288,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"text","id":"ZCzmyWvjIPxIdbushb9XZ","x":-1980.219599435662,"y":2005.4996901427708,"width":460.1509357851104,"height":22.5,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"3 · Queue + Workers + Durable Lambda Functions","fontSize":18,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"3 · Queue + Workers + Durable Lambda Functions","autoResize":false,"lineHeight":1.25,"version":371,"index":"bIX"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["nH6r3YQ23T3uyXmmC_jw7"],"frameId":null,"seed":1638185984,"versionNonce":712653824,"isDeleted":false,"boundElements":[],"updated":1783935467642,"link":null,"locked":false,"type":"ellipse","id":"BHcxs-cGJJhnD0h0pG6wQ","x":-1012.2195994356621,"y":2061.4996901427708,"width":40,"height":40,"strokeColor":"#22C55E","backgroundColor":"#22C55E","roundness":null,"version":322,"index":"bIY"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["nH6r3YQ23T3uyXmmC_jw7"],"frameId":null,"seed":1168980992,"versio