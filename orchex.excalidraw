t_node_attempt = 1;","fontSize":17,"fontFamily":3,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"UPDATE workflow_runs\nSET current_node_id = 'node_response', current_node_attempt = 1\nWHERE id = 'run_01'\n  AND current_node_id = 'node_api'       -- the guard\n  AND current_node_attempt = 1;","autoResize":true,"lineHeight":1.25,"index":"c0Qk"},{"id":"jH22sPZJtpuasWkrPs6dD","type":"text","x":8945.718824618798,"y":9520.071511575481,"width":867.68,"height":63.75,"angle":0,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":1155310413,"versionNonce":930770317,"isDeleted":false,"boundElements":[],"updated":1784708679981,"link":null,"locked":false,"version":95,"text":"Postgres updates one row at a time \u2014 the WHERE clause decides the winner.\nCheck 1 (before executing): read the run; already past this node/attempt? \u2192 stale, drop.\nCheck 2 (when saving): this conditional update. Loser writes nothing, enqueues nothing.","fontSize":17,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Postgres updates one row at a time \u2014 the WHERE clause decides the winner.\nCheck 1 (before executing): read the run; already past this node/attempt? \u2192 stale, drop.\nCheck 2 (when saving): this conditional update. Loser writes nothing, enqueues nothing.","autoResize":true,"lineHeight":1.25,"index":"c0Ql"},{"id":"zJpeBqMP9Eb5KPYcq9V8q","type":"text","x":7605.718824618798,"y":9770.071511575481,"width":1691.28,"height":22.5,"angle":0,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":761573805,"versionNonce":374289389,"isDeleted":false,"boundElements":[],"updated":1784708679982,"link":null,"locked":false,"version":95,"text":"Accepted residual risk: in a tight race both workers may already have fired the external call \u2014 fixing that needs idempotency keys on the external API (deferred).","fontSize":18,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Accepted residual risk: in a tight race both workers may already have fired the external call \u2014 fixing that needs idempotency keys on the external API (deferred).","autoResize":true,"lineHeight":1.25,"index":"c0Qm"},{"id":"9rqXaWh65OUA56HKFK8P_","type":"rectangle","x":7545.718824618798,"y":9940.071511575481,"width":2760,"height":780,"angle":0,"strokeColor":"#adb5bd","backgroundColor":"#f8f9fa","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":983299085,"versionNonce":528232013,"isDeleted":false,"boundElements":[],"updated":1784708679982,"link":null,"locked":false,"version":95,"index":"c0Qn"},{"id":"bs009hI8yafIgmZ9hplKu","type":"text","x":7575.718824618798,"y":9965.071511575481,"width":760.9599999999999,"height":40,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":2021386861,"versionNonce":1104862381,"isDeleted":false,"boundElements":[],"updated":1784708679982,"link":null,"locked":false,"version":95,"text":"4 \u2014 The outbox: no crash can strand a run","fontSize":32,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"4 \u2014 The outbox: no crash can strand a run","autoResize":true,"lineHeight":1.25,"index":"c0Qo"},{"id":"8OxKjED0s8-7D_P6eDMrW","type":"text","x":7575.718824618798,"y":10012.071511575481,"width":1221.48,"height":22.5,"angle":0,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"ro