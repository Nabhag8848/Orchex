      "originalText": "{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"type\": \"integration\",\n  \"category\": \"action\",\n  \"display_name\": \"Integration Action\",\n  \"config_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"provider\", \"action\"],\n    \"properties\": {\n      \"provider\": {\n        \"const\": \"composio\"\n      },\n      \"action\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 256,\n        \"pattern\": \"^[A-Z][A-Z0-9_]*$\",\n        \"description\": \"Composio action id, e.g. GITHUB_CREATE_ISSUE\"\n      },\n      \"params\": {\n        \"type\": \"object\",\n        \"description\": \"Action params; may include templates over input.data\",\n        \"additionalProperties\": {\n          \"type\": [\"object\", \"array\", \"string\", \"number\", \"boolean\", \"null\"]\n        }\n      },\n      \"timeout_ms\": {\n        \"type\": \"integer\",\n        \"minimum\": 1,\n        \"maximum\": 300000,\n        \"default\": 30000\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"input_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"output_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": \"object\",\n        \"required\": [\"action\", \"result\"],\n        \"properties\": {\n          \"action\": {\n            \"type\": \"string\",\n            \"minLength\": 1,\n            \"maxLength\": 256,\n            \"pattern\": \"^[A-Z][A-Z0-9_]*$\"\n          },\n          \"result\": {\n            \"type\": [\"object\", \"array\", \"string\", \"number\", \"boolean\", \"null\"]\n          }\n        },\n        \"additionalProperties\": false\n      }\n    },\n    \"additionalProp