      "originalText": "{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"type\": \"function\",\n  \"category\": \"logic\",\n  \"display_name\": \"Function\",\n  \"config_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"runtime\", \"source\"],\n    \"properties\": {\n      \"runtime\": {\n        \"const\": \"js\"\n      },\n      \"source\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 65536,\n        \"description\": \"Function body; receives input.data, must return value\"\n      },\n      \"timeout_ms\": {\n        \"type\": \"integer\",\n        \"minimum\": 1,\n        \"maximum\": 300000,\n        \"default\": 5000\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"input_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"output_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"data\"],\n    \"properties\": {\n      \"data\": {\n        \"type\": [\"object\", \"array\", \"string\", \"number\", \"boolean\", \"null\"]\n      }\n    },\n    \"additionalProperties\": false\n  },\n  \"error_schema\": {\n    \"type\": \"object\",\n    \"required\": [\"type\", \"code\", \"message\", \"retryable\"],\n    \"properties\": {\n      \"type\": {\n        \"type\": \"string\",\n        \"enum\": [\"validation\", \"operation\", \"timeout\", \"internal\"],\n        \"description\": \"Error class used for UI routing and retry policy\"\n      },\n      \"code\": {\n        \"type\": \"string\",\n        \"enum\": [\"INVALID_INPUT\", \"RUNTIME_ERROR\", \"TIMEOUT\", \"INTERNAL_ERROR\"]\n      },\n      \"message\": {\n        \"type\": \"string\",\n        \"minLength\": 1,\n        \"maxLength\": 512,\n        \"description\": \"Short user-facing summary\"\n      },\n      \"description\":