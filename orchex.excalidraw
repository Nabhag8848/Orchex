    {
      "angle": 0,
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "_SOv5cUzo5qJWttNQPoc-"
      ],
      "frameId": null,
      "seed": 51708928,
      "versionNonce": 2130099200,
      "isDeleted": true,
      "boundElements": [],
