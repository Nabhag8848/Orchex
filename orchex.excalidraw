tion / Response\n\u2022 Durable Lambda (or similar sandbox) \u2014 ONLY for untrusted Function code isolation\n\u2022 Postgres \u2014 workflow_runs, current_node_id, error, context\n\nFlow:\nenqueue execute(node) \u2192 success \u2192 checkpoint \u2192 enqueue successor(s)\nfailure \u2192 store error \u2192 resume later from that node","autoResize":false,"lineHeight":1.25,"version":339,"index":"c0I5"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["CiztIOF2Mp0TVJhrB2HtR"],"frameId":null,"seed":1341390829,"versionNonce":684773933,"isDeleted":false,"boundElements":[],"updated":1784708679957,"link":null,"locked":false,"type":"ellipse","id":"FFvNSpJDzkfTlxi9DG00S","x":-4984.800993484607,"y":11304.852666971017,"width":40,"height":40,"strokeColor":"#22C55E","backgroundColor":"#22C55E","roundness":null,"version":337,"index":"c0I6"},{"angle":0,"fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["CiztIOF2Mp0TVJhrB2HtR"],"frameId":null,"seed":1655142989,"versionNonce":615515277,"isDeleted":false,"boundElements":[],"updated":1784708679957,"link":null,"locked":false,"type":"text","id":"Z8X2eTXPaDHcOql_fqGjT","x":-4973.800993484607,"y":11314.852666971017,"width":160,"height":20,"strokeColor":"#FFFFFF","backgroundColor":"transparent","roundness":null,"text":"I","fontSize":16,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"I","autoResize":true,"lineHeight":1.25,"version":337,"index":"c0I7"},{"angle":0,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":["CiztIOF2Mp0TVJhrB2HtR"],"frameId":null,"seed":431794349,"versionNonce":381283053,"isDeleted":false,"boundElements":[],"updated":1784708679957,"link":null,"locked":false,"type":"rectangle","id":"PwZ09KFh1KPsO5w7xoSYA","x":-5704.800993484607,"y":11300.852666971017,"width":760,"height":78.75,"strokeColor":"#4ADE80","backgroundColor":"#DCFCE7