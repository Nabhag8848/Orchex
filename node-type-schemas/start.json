{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "start",
  "category": "trigger",
  "display_name": "Start",
  "config_schema": {
    "type": "object",
    "properties": {
      "description": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      }
    },
    "additionalProperties": false
  },
  "input_schema": {
    "type": "object",
    "properties": {},
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": "object",
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": ["object", "array", "string", "number", "boolean", "null"]
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
