{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "response",
  "category": "terminal",
  "display_name": "Response",
  "config_schema": {
    "type": "object",
    "required": ["status_code"],
    "properties": {
      "status_code": {
        "type": "integer",
        "enum": [
          100, 101, 102, 103,
          200, 201, 202, 203, 204, 205, 206, 207, 208, 226,
          300, 301, 302, 303, 304, 305, 307, 308,
          400, 401, 402, 403, 404, 405, 406, 407, 408, 409, 410,
          411, 412, 413, 414, 415, 416, 417, 418, 421, 422, 423,
          424, 425, 426, 428, 429, 431, 451,
          500, 501, 502, 503, 504, 505, 506, 507, 508, 510, 511
        ],
        "default": 200
      },
      "body_template": {
        "type": "string",
        "minLength": 1,
        "maxLength": 65536,
        "description": "Template over input.data for final response body"
      },
      "headers": {
        "type": "object",
        "propertyNames": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[A-Za-z0-9!#$%&'*+.^_`|~-]+$"
        },
        "additionalProperties": {
          "type": "string",
          "maxLength": 8192
        }
      }
    },
    "additionalProperties": false
  },
  "input_schema": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": "object",
        "required": ["status_code", "body"],
        "properties": {
          "status_code": {
            "type": "integer",
            "enum": [
              100, 101, 102, 103,
              200, 201, 202, 203, 204, 205, 206, 207, 208, 226,
              300, 301, 302, 303, 304, 305, 307, 308,
              400, 401, 402, 403, 404, 405, 406, 407, 408, 409, 410,
              411, 412, 413, 414, 415, 416, 417, 418, 421, 422, 423,
              424, 425, 426, 428, 429, 431, 451,
              500, 501, 502, 503, 504, 505, 506, 507, 508, 510, 511
            ]
          },
          "headers": {
            "type": "object",
            "propertyNames": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "pattern": "^[A-Za-z0-9!#$%&'*+.^_`|~-]+$"
            },
            "additionalProperties": {
              "type": "string",
              "maxLength": 8192
            }
          },
          "body": {
            "type": ["object", "array", "string", "number", "boolean", "null"]
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
