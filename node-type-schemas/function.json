{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "function",
  "category": "logic",
  "display_name": "Function",
  "config_schema": {
    "type": "object",
    "required": ["runtime", "source"],
    "properties": {
      "runtime": {
        "const": "js"
      },
      "source": {
        "type": "string",
        "minLength": 1,
        "maxLength": 65536,
        "description": "Function body; receives input.data, must return a value"
      },
      "timeout_ms": {
        "type": "integer",
        "minimum": 1,
        "maximum": 300000,
        "default": 5000
      }
    },
    "additionalProperties": false
  },
  "input_schema": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": ["object", "array", "string", "number", "boolean", "null"]
      }
    },
    "additionalProperties": false
  },
  "error_schema": {
    "type": "object",
    "required": ["type", "code", "message", "retryable"],
    "properties": {
      "type": {
        "type": "string",
        "enum": ["validation", "operation", "timeout", "internal"],
        "description": "Error class used for UI routing and retry policy"
      },
      "code": {
        "type": "string",
        "enum": ["INVALID_INPUT", "RUNTIME_ERROR", "TIMEOUT", "INTERNAL_ERROR"]
      },
      "message": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512,
        "description": "Short user-facing summary"
      },
      "description": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048,
        "description": "Optional remediation guidance shown in run history"
      },
      "retryable": {
        "type": "boolean"
      },
      "retry_after_ms": {
        "type": "integer",
        "minimum": 0,
        "maximum": 3600000
      },
      "details": {
        "type": "object",
        "properties": {
          "parameter": {
            "type": "string",
            "maxLength": 256,
            "description": "Config or input field that caused the failure"
          },
          "runtime": {
            "const": "js"
          },
          "timeout_ms": {
            "type": "integer",
            "minimum": 1,
            "maximum": 300000
          },
          "stack": {
            "type": "string",
            "maxLength": 16384
          },
          "cause": {
            "type": "string",
            "maxLength": 4096
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
