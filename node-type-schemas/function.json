{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "function",
  "category": "logic",
  "display_name": "Function",
  "config_schema": {
    "type": "object",
    "required": ["runtime", "source"],
    "properties": {
      "runtime": {
        "const": "js"
      },
      "source": {
        "type": "string",
        "minLength": 1,
        "maxLength": 65536,
        "description": "Function body; receives input.data, must return a value"
      },
      "timeout_ms": {
        "type": "integer",
        "minimum": 1,
        "maximum": 300000,
        "default": 5000
      }
    },
    "additionalProperties": false
  },
  "input_schema": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": ["object", "array", "string", "number", "boolean", "null"]
      }
    },
    "additionalProperties": false
  }
}
