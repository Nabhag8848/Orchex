{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "conditional",
  "category": "logic",
  "display_name": "Conditional",
  "config_schema": {
    "type": "object",
    "required": ["expression"],
    "properties": {
      "expression": {
        "type": "string",
        "minLength": 1,
        "maxLength": 4096,
        "description": "Boolean expression over input.data, e.g. data.payload.status == 200"
      }
    },
    "additionalProperties": false
  },
  "input_schema": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": "object",
        "required": ["branch"],
        "properties": {
          "branch": {
            "type": "string",
            "enum": ["true", "false"]
          }
        },
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  },
  "error_schema": {
    "type": "object",
    "required": ["type", "code", "message", "retryable"],
    "properties": {
      "type": {
        "type": "string",
        "enum": ["validation", "operation", "internal"],
        "description": "Error class used for UI routing and retry policy"
      },
      "code": {
        "type": "string",
        "enum": ["INVALID_INPUT", "EXPRESSION_ERROR", "INTERNAL_ERROR"]
      },
      "message": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512,
        "description": "Short user-facing summary"
      },
      "description": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048,
        "description": "Optional remediation guidance shown in run history"
      },
      "retryable": {
        "type": "boolean"
      },
      "retry_after_ms": {
        "type": "integer",
        "minimum": 0,
        "maximum": 3600000
      },
      "details": {
        "type": "object",
        "properties": {
          "parameter": {
            "type": "string",
            "maxLength": 256,
            "description": "Config or input field that caused the failure"
          },
          "expression": {
            "type": "string",
            "maxLength": 4096
          },
          "cause": {
            "type": "string",
            "maxLength": 4096
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
