{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "integration",
  "category": "action",
  "display_name": "Integration Action",
  "config_schema": {
    "type": "object",
    "required": ["provider", "action"],
    "properties": {
      "provider": {
        "const": "composio"
      },
      "action": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256,
        "pattern": "^[A-Z][A-Z0-9_]*$",
        "description": "Composio action id, e.g. GITHUB_CREATE_ISSUE"
      },
      "params": {
        "type": "object",
        "description": "Action params; may include templates over input.data",
        "additionalProperties": {
          "type": ["object", "array", "string", "number", "boolean", "null"]
        }
      },
      "timeout_ms": {
        "type": "integer",
        "minimum": 1,
        "maximum": 300000,
        "default": 30000
      }
    },
    "additionalProperties": false
  },
  "input_schema": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": "object",
        "required": ["action", "result"],
        "properties": {
          "action": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "result": {
            "type": ["object", "array", "string", "number", "boolean", "null"]
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  },
  "error_schema": {
    "type": "object",
    "required": ["type", "code", "message", "retryable"],
    "properties": {
      "type": {
        "type": "string",
        "enum": ["validation", "operation", "auth", "api", "timeout", "rate_limit", "internal"],
        "description": "Error class used for UI routing and retry policy"
      },
      "code": {
        "type": "string",
        "enum": [
          "INVALID_INPUT",
          "INVALID_CONFIG",
          "AUTH_EXPIRED",
          "ACTION_FAILED",
          "TIMEOUT",
          "NETWORK_ERROR",
          "RATE_LIMITED",
          "INTERNAL_ERROR"
        ]
      },
      "message": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512,
        "description": "Short user-facing summary"
      },
      "description": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048,
        "description": "Optional remediation guidance shown in run history"
      },
      "retryable": {
        "type": "boolean"
      },
      "retry_after_ms": {
        "type": "integer",
        "minimum": 0,
        "maximum": 3600000,
        "description": "Suggested delay before retry (e.g. rate limits / auth refresh)"
      },
      "http_status": {
        "type": "integer",
        "enum": [
          100, 101, 102, 103,
          200, 201, 202, 203, 204, 205, 206, 207, 208, 226,
          300, 301, 302, 303, 304, 305, 307, 308,
          400, 401, 402, 403, 404, 405, 406, 407, 408, 409, 410,
          411, 412, 413, 414, 415, 416, 417, 418, 421, 422, 423,
          424, 425, 426, 428, 429, 431, 451,
          500, 501, 502, 503, 504, 505, 506, 507, 508, 510, 511
        ]
      },
      "details": {
        "type": "object",
        "properties": {
          "parameter": {
            "type": "string",
            "maxLength": 256,
            "description": "Config or input field that caused the failure"
          },
          "provider": {
            "const": "composio"
          },
          "action": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "provider_error": {
            "type": ["object", "array", "string", "number", "boolean", "null"]
          },
          "timeout_ms": {
            "type": "integer",
            "minimum": 1,
            "maximum": 300000
          },
          "cause": {
            "type": "string",
            "maxLength": 4096
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
